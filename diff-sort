#!/usr/bin/env bb

; Sorts files in a .diff by a variety of metrics: number of additions,
; deletions, alphabetically, similarity, size, and whether it's a test.

(ns diff-sort
  (:require [clojure.string :as str]
            diff
            util))

(def sorters
  {:additions (fn [text]
                (->> text
                     str/split-lines
                     (filter #(str/starts-with? % "+"))
                     count
                     -))
   :alphabetical identity
   :deletions (fn [text]
                (->> text
                     str/split-lines
                     (filter #(str/starts-with? % "-"))
                     count
                     -))
   :percent-deletions (fn [text]
                       (let [lines (str/split-lines text)
                             total (->> lines
                                        (filter #(re-find #"^[ +-]" %))
                                        count)
                             deletions (->> lines
                                            (filter #(str/starts-with? % "-"))
                                            count)]
                         (if (zero? total)
                           0
                           (- (/ deletions total)))))
   :similarity (fn [text]
                 (let [additions (->> text
                                      str/split-lines
                                      (filter #(str/starts-with? % "+"))
                                      count)
                       deletions (->> text
                                      str/split-lines
                                      (filter #(str/starts-with? % "-"))
                                      count)]
                   (Math/abs (- additions deletions))))
   :size (comp count str/split-lines)
   :test (fn [text]
           (let [[line] (str/split-lines text)]
             (if (re-find #"\btests?\b|_tests\.py" line) 1 0)))})

(let [[metric] *command-line-args*]
  (when-not metric
    (let [metrics (->> (keys sorters)
                       (map name)
                       (str/join ", "))]
      (util/abort (str "Must specify a sorting metric: " metrics))))
  (->> (slurp *in*)
       diff/files
       (sort-by (sorters (keyword metric)))
       (str/join "\n")
       println))
